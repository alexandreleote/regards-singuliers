<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}Welcome!{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2776%22 fill=%22%23fff%22>sf</text></svg>">
        
        {# Styles #}
        {% block stylesheets %}
            <link rel="stylesheet" href="{{ asset('styles/style.css') }}">
        {% endblock %}

        {# Scripts #}
        {% block javascripts %}
            <script type="module" src="{{ asset('js/script.js') }}"></script>
        {% endblock %}
    </head>
    <body>

        {% if app.request.attributes.get('_route') not in ['app_login', 'app_register'] %}
            {% include "partials/navbar.html.twig" %}
        {% endif %}

        <main>
            
            {% block body %}{% endblock %}
        
        </main>

        {% if app.request.attributes.get('_route') not in ['app_login', 'app_register'] %}
            {% include "partials/footer.html.twig" %}
        {% endif %}
        
    </body>
</html>
